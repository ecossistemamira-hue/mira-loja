# Supabase da Mira (mesmo projeto do mira-platform). A loja lê via ANON key —
# só produtos publicados+aprovados, garantido pelas RLS policies `produtos_publico`
# e `produto_fotos_publico` (migration 0081 do mira-platform).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública da loja (usada em canonical, sitemap, JSON-LD).
NEXT_PUBLIC_SITE_URL=http://localhost:3100

# Número de WhatsApp (só dígitos, com DDI) pro CTA temporário de compra da Fase 1.
NEXT_PUBLIC_WHATSAPP=595000000000

# Service role key do Supabase — SÓ servidor (criar pedidos, baixar estoque,
# webhook). NUNCA prefixar com NEXT_PUBLIC. RLS é ignorada por esta chave.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — e-mails transacionais (pedido recebido / pagamento confirmado).
# Reusa a conta/domínio verificado do mira-platform (mirafranquicia.com).
RESEND_API_KEY=
RESEND_FROM_EMAIL=Mira Shop <no-reply@mirafranquicia.com>

# Secret do Vercel Cron (expira pedidos não pagos). O Vercel envia como
# Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# Secret do webhook de pagamento genérico (header x-webhook-secret).
WEBHOOK_SECRET=

# Mercado Pago (Fase 2 — quando houver credenciais). Sem isto, o webhook /mp
# só responde 200 ao ping de validação e não age.
# MP_ACCESS_TOKEN=
# MP_WEBHOOK_SECRET=
