# Supabase da Mira (mesmo projeto do mira-platform). A loja lê via ANON key —
# só produtos publicados+aprovados, garantido pelas RLS policies `produtos_publico`
# e `produto_fotos_publico` (migration 0081 do mira-platform).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública da loja (usada em canonical, sitemap, JSON-LD).
NEXT_PUBLIC_SITE_URL=http://localhost:3100

# Número de WhatsApp (só dígitos, com DDI) pro CTA temporário de compra da Fase 1.
NEXT_PUBLIC_WHATSAPP=595000000000

# Service role key do Supabase — SÓ servidor (criar pedidos, baixar estoque,
# webhook). NUNCA prefixar com NEXT_PUBLIC. RLS é ignorada por esta chave.
SUPABASE_SERVICE_ROLE_KEY=
